{
    "name": "songdrive-vscode",
    "displayName": "SongDrive Syntax Support",
    "description": "Syntax highlighting for SongDrive song files",
    "version": "0.2.0",
    "license": "MIT",
    "icon": "logo.png",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "songdrive",
        "chords",
        "lyrics",
        "songs",
        "syntax highlighting"
    ],
    "author": {
        "name": "Andreas Müller",
        "url": "https://devmount.com"
    },
    "publisher": "devmount",
    "repository": {
        "type": "git",
        "url": "https://github.com/devmount/songdrive-vscode"
    },
    "contributes": {
        "languages": [
            {
                "id": "songdrive",
                "aliases": [
                    "SongDrive",
                    "songdrive"
                ],
                "extensions": [
                    ".songdrive",
                    ".sd"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "songdrive",
                "scopeName": "source.songdrive",
                "path": "./syntaxes/songdrive.json"
            }
        ]
    },
    "scripts": {
        "build": "npx vsce package"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.9.2"
    }
}
