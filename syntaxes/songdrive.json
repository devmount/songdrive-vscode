{
    "fileTypes": [
        "songdrive",
        "sd"
    ],
    "name": "songdrive",
    "patterns": [
        {
            "include": "#marker"
        },
        {
            "include": "#chordLine"
        }
    ],
    "repository": {
        "marker": {
            "match": "^--(v|p|c|b|i|m|o)\\d*[ \\t]*$",
            "name": "comment.line.marker.songdrive"
        },
        "chordLine": {
            "begin": "^(?=.*\\S[ \\t]{2,}$)",
            "end": "$",
            "patterns": [
                {
                    "match": "\\S+",
                    "name": "string.other.chord.songdrive"
                }
            ]
        }
    },
    "scopeName": "source.songdrive"
}
